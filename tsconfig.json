{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "src/contexts/LanguageContext.jsx",
    "src/components/Header/LanguageChanger.jsx",
    "src/components/Header/index.jsx",
    "src/components/Header/Sidebar/index.jsx",
    "src/components/Header/Navigation/mobileheaderLinks.jsx",
    "src/components/Header/Navigation/menuData.jsx",
    "src/components/Header/Navigation/headerLinks.jsx",
    "src/app/layout.jsx",
    "src/app/page.jsx"
  ],
  "exclude": [
    "node_modules"
  ]
}